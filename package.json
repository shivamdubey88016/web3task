{
  "name": "watch-party-monorepo",
  "version": "1.0.0",
  "description": "Watch Party Real-Time Sync System",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm install --prefix server && npm install --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:frontend",
    "start": "node server/src/index.js",
    "dev:server": "node server/src/index.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
